/*ETIQUETAS HTML*/

/* 1 */
body{
    font-family: Arial, sans-serif;
    background-color: #f5f5f5;
}

/* 2 */
h1{
    color: darkgreen;
    text-align: center;
}

/* 3 */
h2{
    color: #2e7d32;
}

/* 4 */
p{
    color: #555;
    line-height: 1.5;
}

/* 5 */
button{
    background-color: green;
    color: white;
    border: none;
    padding: 10px;
    border-radius: 5px;
}

/*ETIQUETAS CLASS*/

/* 1 */
.header{
    background-color: #dcedc8;
    padding: 5px;
}

/* 2 */
.logo{
    width: 80px;
}
/* 3 */
.section1{
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 250px 250px;
    gap: 15px;
    background-color: white;
    padding: 20px;
}

.section1 section{
    display:flex;
    align-items:center;
    background:#e8f5e9;
}

.section1 section:first-child{
    grid-column: span 2;
}

.section1 section{
    overflow: hidden;
    border-radius: 10px;
}

.section1 img{
    max-width:100%;
    max-height:250px;
    object-fit:contain;
}

/* 4 */
.card{
    border: 1px solid #ccc;
    border-radius: 10px;
    padding: 15px;
    background-color: white;
}

/* 5 */
.footer{
    background-color: #2e7d32;
    color: white;
    padding: 20px;
}

.footer p{
    color: white;
}

.copyright{
    color: white;
}

/*ETIQUETAS IDENTIFICADOR*/

/* 1 */
#inicio{
    border: 3px solid green;
}

/* 2 */
#secciones{
    background-color: #f1f8e9;
}

/* 3 */
#productos{
    background-color: #ffffff;
}

/* 4 */
#contacto{
    background-color: #e8f5e9;
}

/* 5 */
#formCompleto{
    border: 2px solid #4caf50;
    padding: 20px;
    border-radius: 10px;
}
